# Local Ollama model used by the solve step.
# Default model in code is qwen3.5:4b.
OLLAMA_MODEL=qwen3.5:4b

# Ollama server URL (default is local desktop server).
OLLAMA_BASE_URL=http://localhost:11434

# Optional path to local Tesseract binary if pytesseract cannot find it.
# Example macOS: /opt/homebrew/bin/tesseract
TESSERACT_CMD=