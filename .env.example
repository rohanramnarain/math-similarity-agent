# Solve backend: huggingface (default) or ollama.
LLM_BACKEND=huggingface

# Hugging Face model configuration (default: Gemma 4 E2B instruction model).
HF_MODEL_ID=google/gemma-4-E2B-it
HF_TOKEN=
HF_MAX_NEW_TOKENS=512
# Device for HF inference: mps, cpu, or auto.
HF_DEVICE=mps

# Optional Ollama fallback configuration.
OLLAMA_MODEL=gemma4:e2b-it

# Ollama server URL (default is local desktop server).
OLLAMA_BASE_URL=http://localhost:11434

# Optional path to local Tesseract binary if pytesseract cannot find it.
# Example macOS: /opt/homebrew/bin/tesseract
TESSERACT_CMD=